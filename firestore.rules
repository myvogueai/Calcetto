rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // The game session document is readable and writable by anyone with the link.
    // All validation logic lives in the app (PIN checks, transactions).
    // For production you can tighten these rules.
    match /calcetto/{sessionId} {
      allow read, write: if true;
    }
  }
}
